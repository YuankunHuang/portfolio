---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("writing", (e) => !e.data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-CA", { year: "numeric", month: "2-digit", day: "2-digit" });
---

<Layout
  title="Writing — Yuankun Huang"
  description="Notes on Unity client engineering, native interop, and real-time systems."
>
  <section class="section writing-index" aria-label="Writing">
    <div class="container">
      <nav class="writing-index__nav" aria-label="Breadcrumb">
        <a href="/" class="arrow-link">← Home</a>
      </nav>

      <div class="writing-index__head">
        <h1 class="section-label">Writing</h1>
        <a href="/rss.xml" class="arrow-link arrow-link--muted">RSS</a>
      </div>

      {
        posts.length === 0 ? (
          <p class="writing-index__empty">Nothing published yet — first notes are on the way.</p>
        ) : (
          <ul class="writing-index__list">
            {posts.map((post, i) => (
              <li class="writing-index__row reveal" style={`--reveal-delay: ${i * 40}ms`}>
                <span class="writing-index__date">{fmt(post.data.date)}</span>
                <div class="writing-index__main">
                  <a href={`/writing/${post.id}/`} class="writing-index__title">
                    {post.data.title}
                  </a>
                  <span class="writing-index__summary">{post.data.summary}</span>
                  {post.data.tags.length > 0 && (
                    <span class="writing-index__tags">{post.data.tags.join(" · ")}</span>
                  )}
                </div>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .writing-index__nav {
    padding-block: 16px 0;
  }

  .writing-index__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-top: 24px;
    margin-bottom: 16px;
  }

  .writing-index__head h1 {
    font-weight: 400;
  }

  .arrow-link--muted {
    color: var(--muted);
  }

  .arrow-link--muted:hover {
    color: var(--accent-2);
  }

  .writing-index__empty {
    font-size: var(--text-sm);
    color: var(--muted);
    border-top: 1px solid var(--hairline);
    padding-top: 20px;
  }

  .writing-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--hairline);
  }

  .writing-index__row {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 4px 24px;
    padding-block: 14px;
    border-bottom: 1px solid var(--hairline);
    align-items: baseline;
  }

  .writing-index__date {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    font-variant-numeric: tabular-nums;
    color: var(--muted);
  }

  .writing-index__main {
    display: flex;
    flex-direction: column;
    gap: 3px;
    max-width: var(--measure);
  }

  .writing-index__title {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: 550;
    color: var(--ink);
    text-decoration: none;
  }

  .writing-index__title:hover {
    color: var(--accent);
  }

  .writing-index__summary {
    font-size: var(--text-xs);
    color: var(--ink);
  }

  .writing-index__tags {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .writing-index__row {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
