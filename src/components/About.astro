---
import { Image } from "astro:assets";
import { about, contact, site } from "../data/site";
import profile from "../assets/profile.png";

interface Props {
  num?: string;
}

const { num = "02" } = Astro.props;
---

<section class="section about-section" id="about" aria-label="About and contact">
  <div class="container">
    <p class="section-label about-section__head">
      <span class="section-num">{num}</span>About
    </p>

    <div class="about-section__grid">
      <div class="about-section__narrative">
        <div class="about-section__intro">
          <div class="about-section__photo">
            <Image
              src={profile}
              alt="Yuankun Huang at his desk, mid-debug session"
              widths={[160, 240, 320]}
              sizes="120px"
              loading="lazy"
            />
          </div>
          <div>
            <h2 class="about-section__heading reveal">{about.heading}</h2>
            <p class="about-section__message reveal" style="--reveal-delay: 40ms">
              {contact.message}
            </p>
          </div>
        </div>

        <div class="prose about-section__prose">
          {
            about.paragraphs.map((para, i) => (
              <p class="about-section__para reveal" style={`--reveal-delay: ${80 + i * 60}ms`}>
                {para}
              </p>
            ))
          }
        </div>
      </div>

      <aside class="about-section__facts" id="contact" aria-label="Contact and facts">
        <dl class="facts">
          {
            contact.methods.map((method) => (
              <div class="facts__row">
                <dt class="facts__label">{method.label}</dt>
                <dd class="facts__value">
                  <a
                    href={method.href}
                    target={method.href.startsWith("mailto") ? undefined : "_blank"}
                    rel={method.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
                  >
                    {method.value}
                  </a>
                </dd>
              </div>
            ))
          }
          <div class="facts__row">
            <dt class="facts__label">Resume</dt>
            <dd class="facts__value">
              <a href={site.resumeHref} download={site.resumeDownloadName}>PDF ↓</a>
            </dd>
          </div>
          <div class="facts__row">
            <dt class="facts__label">Skills</dt>
            <dd class="facts__value facts__value--mono">{about.skills}</dd>
          </div>
          <div class="facts__row">
            <dt class="facts__label">Education</dt>
            <dd class="facts__value facts__value--mono">{about.education}</dd>
          </div>
          <div class="facts__row">
            <dt class="facts__label">Eligibility</dt>
            <dd class="facts__value facts__value--mono">{contact.eligibility}</dd>
          </div>
          <div class="facts__row">
            <dt class="facts__label">Archive</dt>
            <dd class="facts__value">
              <a href={about.archive.url} target="_blank" rel="noopener noreferrer">
                {about.archive.label} ↗
              </a>
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-section {
    border-top: 1px solid var(--rule);
  }

  .about-section__head {
    margin-bottom: 20px;
  }

  .about-section__grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
    gap: 24px 48px;
    align-items: start;
  }

  .about-section__intro {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .about-section__photo {
    flex: 0 0 auto;
    width: 96px;
  }

  .about-section__photo :global(img) {
    border-radius: 6px;
    box-shadow: var(--shadow);
  }

  .about-section__heading {
    font-size: var(--text-xl);
  }

  .about-section__message {
    font-size: var(--text-sm);
    color: var(--muted);
    margin-top: 6px;
    text-wrap: pretty;
  }

  .about-section__prose {
    margin-top: 20px;
  }

  .about-section__para {
    font-size: var(--text-sm);
  }

  .about-section__facts {
    border-left: 1px solid var(--hairline);
    padding-left: 28px;
  }

  .facts {
    margin: 0;
    display: grid;
  }

  .facts__row {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 4px 16px;
    padding-block: 10px;
  }

  .facts__row + .facts__row {
    border-top: 1px solid var(--hairline);
  }

  .facts__label {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    padding-top: 2px;
  }

  .facts__value {
    margin: 0;
    font-size: var(--text-xs);
    line-height: 1.55;
  }

  .facts__value--mono {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--ink);
  }

  .facts__value a {
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .about-section__grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .about-section__facts {
      border-left: none;
      border-top: 1px solid var(--hairline);
      padding-left: 0;
      padding-top: 16px;
    }
  }

  @media (max-width: 480px) {
    .about-section__intro {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
