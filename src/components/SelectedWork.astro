---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

interface Props {
  num?: string;
}

const { num = "01" } = Astro.props;

const work = (await getCollection("work", (e) => e.data.featured)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section class="section selected-work" id="work" aria-label="Selected work">
  <div class="container">
    <div class="selected-work__head">
      <p class="section-label"><span class="section-num">{num}</span>Selected Work</p>
      <a href="/work/" class="arrow-link">All work →</a>
    </div>

    <div class="work-index">
      {
        work.map((project, i) => (
          <article class="work-row reveal" aria-label={project.data.title}>
            <span class="work-row__num" aria-hidden="true">
              {String(i + 1).padStart(2, "0")}
            </span>

            <div class="work-row__body">
              <h2 class="work-row__title">
                <a href={`/work/${project.id}/`}>{project.data.title}</a>
              </h2>
              <p class="work-row__summary">{project.data.summary}</p>
              {project.data.outcome && (
                <p class="work-row__outcome">
                  <span class="work-row__outcome-label" aria-hidden="true">
                    →
                  </span>
                  {project.data.outcome}
                </p>
              )}
              <div class="work-row__links">
                <a
                  href={`/work/${project.id}/`}
                  class="arrow-link"
                  aria-label={`Full case study for ${project.data.title}`}
                >
                  ↗ Case study
                </a>
                {project.data.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="arrow-link arrow-link--muted"
                  >
                    ↗ {link.label}
                  </a>
                ))}
                {project.data.video && (
                  <button
                    type="button"
                    class="arrow-link arrow-link--muted work-row__demo-btn"
                    data-demo-type="video"
                    data-demo-src={project.data.video.src}
                    data-demo-poster={project.data.video.poster?.src}
                    data-demo-title={`${project.data.title} — demo video`}
                  >
                    ▶ Demo
                  </button>
                )}
              </div>
            </div>

            <div class="work-row__meta">
              <div class="work-row__meta-item">
                <span class="meta-label">Period</span>
                <span class="meta-value">{project.data.period}</span>
              </div>
              <div class="work-row__meta-item">
                <span class="meta-label">Role</span>
                <span class="meta-value">{project.data.role}</span>
              </div>
              <div class="work-row__meta-item">
                <span class="meta-label">Stack</span>
                <span class="work-row__stack">{project.data.stack.join(" · ")}</span>
              </div>
            </div>

            {project.data.cover && (
              <a
                href={`/work/${project.id}/`}
                class="work-row__thumb"
                tabindex="-1"
                aria-hidden="true"
              >
                <Image
                  src={project.data.cover.src}
                  alt=""
                  widths={[240, 480, 720]}
                  sizes="(max-width: 820px) calc(100vw - 40px), 220px"
                  style={`object-position: ${project.data.cover.position}`}
                  loading="lazy"
                />
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .selected-work {
    border-top: 1px solid var(--rule);
  }

  .selected-work__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .work-index {
    border-top: 1px solid var(--hairline);
  }

  .work-row {
    display: grid;
    grid-template-columns: 44px minmax(0, 6fr) minmax(0, 3fr) 220px;
    gap: 12px 28px;
    padding-block: 22px;
    border-bottom: 1px solid var(--hairline);
    align-items: start;
  }

  .work-row__num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    color: var(--accent-2);
    padding-top: 6px;
  }

  .work-row__title {
    font-size: var(--text-lg);
  }

  .work-row__title a {
    color: var(--ink);
    text-decoration: none;
  }

  .work-row__title a:hover {
    color: var(--accent);
  }

  .work-row__summary {
    font-size: var(--text-sm);
    color: var(--ink);
    margin-top: 6px;
    max-width: var(--measure);
  }

  .work-row__outcome {
    font-size: var(--text-xs);
    color: var(--muted);
    margin-top: 8px;
    max-width: var(--measure);
    padding-left: 1.2em;
    position: relative;
  }

  .work-row__outcome-label {
    position: absolute;
    left: 0;
    color: var(--accent-2);
  }

  .work-row__links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    margin-top: 12px;
  }

  .work-row__demo-btn {
    text-align: left;
  }

  .work-row__meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-left: 1px solid var(--hairline);
    padding-left: 20px;
  }

  .work-row__stack {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--muted);
    line-height: 1.6;
  }

  .work-row__thumb {
    display: block;
    border-radius: 4px;
    overflow: hidden;
  }

  .work-row__thumb :global(img) {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform var(--transition);
  }

  .work-row__thumb:hover :global(img) {
    transform: scale(1.03);
  }

  @media (max-width: 1080px) {
    .work-row {
      grid-template-columns: 44px minmax(0, 6fr) minmax(0, 3fr);
    }

    .work-row__thumb {
      grid-column: 2;
      max-width: 320px;
    }
  }

  @media (max-width: 820px) {
    .work-row {
      grid-template-columns: 36px minmax(0, 1fr);
    }

    .work-row__meta {
      grid-column: 2;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 12px 28px;
      border-left: none;
      padding-left: 0;
    }

    .work-row__thumb {
      grid-column: 2;
    }
  }
</style>
