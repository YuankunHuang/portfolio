---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import OtherWork from "./OtherWork.astro";

const work = (await getCollection("work")).sort((a, b) => a.data.order - b.data.order);
---

<section class="section selected-work" id="work" aria-label="Selected work">
  <div class="container">
    <p class="section-label selected-work__header">Selected Work</p>

    {
      work.map((project, i) => (
        <article
          class:list={["case-study", "reveal", { "case-study--bordered": i < work.length - 1 }]}
          aria-label={project.data.title}
        >
          <div class="asymmetric-layout">
            <aside class="case-study__meta">
              <div class="case-study__meta-item">
                <span class="meta-label">Period</span>
                <span class="meta-value">{project.data.period}</span>
              </div>
              <div class="case-study__meta-item">
                <span class="meta-label">Role</span>
                <span class="meta-value">{project.data.role}</span>
              </div>
              <div class="case-study__meta-item">
                <span class="meta-label">Team</span>
                <span class="meta-value">{project.data.team}</span>
              </div>
              <div class="case-study__meta-item case-study__tags">
                {project.data.stack.map((s) => (
                  <span class="stack-tag">{s}</span>
                ))}
              </div>
              <div class="case-study__meta-item case-study__links">
                <a
                  href={`/work/${project.id}/`}
                  class="arrow-link"
                  aria-label={`Full case study for ${project.data.title}`}
                >
                  ↗ Case study
                </a>
                {project.data.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="arrow-link arrow-link--muted"
                  >
                    ↗ {link.label}
                  </a>
                ))}
                {project.data.video && (
                  <button
                    type="button"
                    class="arrow-link arrow-link--muted case-study__demo-btn"
                    data-demo-type="video"
                    data-demo-src={project.data.video.src}
                    data-demo-poster={project.data.video.poster?.src}
                    data-demo-title={`${project.data.title} — demo video`}
                  >
                    ↳ Watch demo
                  </button>
                )}
              </div>
            </aside>

            <div class="case-study__body">
              <h2 class="case-study__title">
                <a href={`/work/${project.id}/`}>{project.data.title}</a>
              </h2>
              <hr class="rule case-study__rule" />

              <div class="case-study__prose prose">
                <div class="case-study__block">
                  <h3 class="case-study__block-label">Context</h3>
                  <p>{project.data.context}</p>
                </div>
                <div class="case-study__block">
                  <h3 class="case-study__block-label">Decision</h3>
                  <p>{project.data.decision}</p>
                </div>
                <div class="case-study__block">
                  <h3 class="case-study__block-label">Outcome</h3>
                  <p>{project.data.outcome}</p>
                </div>
              </div>

              <div class="case-study__image">
                <a href={`/work/${project.id}/`} tabindex="-1" aria-hidden="true">
                  <Image
                    src={project.data.cover.src}
                    alt={project.data.cover.alt}
                    widths={[480, 800, 1200, 1600]}
                    sizes="(max-width: 820px) calc(100vw - 40px), min(66vw, 840px)"
                    style={`object-position: ${project.data.cover.position}`}
                    loading="lazy"
                  />
                </a>
                {project.data.video && (
                  <button
                    type="button"
                    class="case-study__overlay-btn"
                    data-demo-type="video"
                    data-demo-src={project.data.video.src}
                    data-demo-poster={project.data.video.poster?.src}
                    data-demo-title={`${project.data.title} — demo video`}
                    aria-label={`Watch ${project.data.title} demo`}
                  >
                    ▶&nbsp;&nbsp;Watch demo
                  </button>
                )}
              </div>
            </div>
          </div>
        </article>
      ))
    }

    <OtherWork />
  </div>
</section>

<style>
  .selected-work {
    border-top: 1px solid var(--rule);
  }

  .selected-work__header {
    margin-bottom: 48px;
  }

  .case-study {
    padding-block: 40px 56px;
  }

  .case-study--bordered {
    border-bottom: 1px solid var(--rule);
  }

  .case-study__meta {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-content: start;
  }

  .case-study__tags {
    margin-top: 8px;
  }

  .case-study__links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    margin-top: 14px;
  }

  .arrow-link--muted {
    color: var(--muted);
  }

  .arrow-link--muted:hover {
    color: var(--accent-2);
  }

  .case-study__demo-btn {
    text-align: left;
  }

  .case-study__title {
    font-size: var(--text-xl);
  }

  .case-study__title a {
    color: var(--ink);
    text-decoration: none;
  }

  .case-study__title a:hover {
    color: var(--accent);
  }

  .case-study__rule {
    margin: 16px 0 28px;
  }

  .case-study__block + .case-study__block {
    margin-top: 24px;
  }

  .case-study__block-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .case-study__block p {
    font-size: var(--text-sm);
    color: var(--ink);
  }

  .case-study__image {
    position: relative;
    margin-top: 36px;
    max-width: 840px;
  }

  .case-study__image :global(img) {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 6px;
    box-shadow: var(--shadow);
  }

  .case-study__overlay-btn {
    position: absolute;
    left: 16px;
    bottom: 16px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: #fff;
    background: rgba(12, 11, 9, 0.72);
    border-radius: 4px;
    padding: 8px 14px;
    transition: background-color var(--transition);
  }

  .case-study__overlay-btn:hover {
    background: rgba(12, 11, 9, 0.9);
  }

  @media (max-width: 820px) {
    .case-study__meta {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px 32px;
    }

    .case-study__links {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: 0;
      width: 100%;
    }
  }
</style>
