---
import { now } from "../data/site";
---

<section class="section now-section" id="now" aria-label="What I'm doing now">
  <div class="container">
    <div class="asymmetric-layout">
      <div>
        <p class="section-label">Now</p>
        <p class="now-section__updated">Updated {now.updated}</p>
      </div>

      <dl class="now-section__items">
        {
          now.items.map((item, i) => (
            <div class="now-section__row reveal" style={`--reveal-delay: ${i * 70}ms`}>
              <dt class:list={["now-section__label", { "now-section__label--featured": i === 0 }]}>
                {item.label}
              </dt>
              <dd class="now-section__value">{item.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>

<style>
  .now-section {
    border-top: 1px solid var(--rule);
  }

  .now-section__updated {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 6px;
  }

  .now-section__items {
    display: grid;
    gap: 20px;
    margin: 0;
  }

  .now-section__row {
    display: grid;
    grid-template-columns: 130px minmax(0, 1fr);
    gap: 8px 24px;
    max-width: var(--measure);
  }

  .now-section__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    white-space: nowrap;
  }

  .now-section__label--featured {
    color: var(--accent-2);
  }

  .now-section__value {
    margin: 0;
    font-size: var(--text-sm);
  }

  @media (max-width: 560px) {
    .now-section__row {
      grid-template-columns: minmax(0, 1fr);
      gap: 2px;
    }
  }
</style>
