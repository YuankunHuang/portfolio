---
import { getCollection } from "astro:content";

interface Props {
  num?: string;
}

const { num = "02" } = Astro.props;

const posts = (await getCollection("writing", (e) => !e.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-CA", { year: "numeric", month: "2-digit", day: "2-digit" });
---

{
  posts.length > 0 && (
    <section class="section recent-writing" id="writing" aria-label="Recent writing">
      <div class="container">
        <div class="recent-writing__head">
          <p class="section-label">
            <span class="section-num">{num}</span>Writing
          </p>
          <a href="/writing/" class="arrow-link">
            All posts →
          </a>
        </div>

        <ul class="recent-writing__list">
          {posts.map((post, i) => (
            <li class="recent-writing__row reveal" style={`--reveal-delay: ${i * 50}ms`}>
              <span class="recent-writing__date">{fmt(post.data.date)}</span>
              <div class="recent-writing__main">
                <a href={`/writing/${post.id}/`} class="recent-writing__title">
                  {post.data.title}
                </a>
                <span class="recent-writing__summary">{post.data.summary}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}

<style>
  .recent-writing {
    border-top: 1px solid var(--rule);
  }

  .recent-writing__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .recent-writing__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--hairline);
  }

  .recent-writing__row {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 4px 24px;
    padding-block: 12px;
    border-bottom: 1px solid var(--hairline);
    align-items: baseline;
  }

  .recent-writing__date {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    font-variant-numeric: tabular-nums;
    color: var(--muted);
  }

  .recent-writing__main {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
    align-items: baseline;
    max-width: var(--measure);
  }

  .recent-writing__title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
  }

  .recent-writing__title:hover {
    color: var(--accent);
  }

  .recent-writing__summary {
    font-size: var(--text-xs);
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .recent-writing__row {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
