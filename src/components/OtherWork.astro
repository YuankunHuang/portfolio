---
import { getCollection } from "astro:content";

const items = (await getCollection("otherWork")).sort((a, b) =>
  b.data.year.localeCompare(a.data.year),
);
---

<div class="other-work" aria-label="Other work">
  <div class="asymmetric-layout">
    <p class="section-label other-work__label">Other Work</p>

    <ul class="other-work__list">
      {
        items.map((item, i) => (
          <li class="other-work__row reveal" style={`--reveal-delay: ${i * 50}ms`}>
            <span class="other-work__year">{item.data.year}</span>
            <div class="other-work__main">
              <span class="other-work__project">
                {item.data.link ? (
                  <a href={item.data.link.url} target="_blank" rel="noopener noreferrer">
                    {item.data.project}
                  </a>
                ) : (
                  item.data.project
                )}
              </span>
              <span class="other-work__desc">{item.data.description}</span>
              <span class="other-work__stack">{item.data.stack}</span>
            </div>
            <span class="other-work__actions">
              {item.data.link && (
                <a
                  href={item.data.link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="arrow-link"
                  aria-label={`${item.data.project} — ${item.data.link.label}`}
                >
                  ↗ {item.data.link.label}
                </a>
              )}
              {item.data.demo && (
                <button
                  type="button"
                  class="arrow-link other-work__demo-btn"
                  data-demo-type={item.data.demo.type}
                  data-demo-src={item.data.demo.src}
                  data-demo-title={
                    item.data.demo.type === "webgl"
                      ? item.data.demo.title
                      : `${item.data.project} — demo video`
                  }
                  aria-label={`${item.data.project} demo`}
                >
                  ▶ demo
                </button>
              )}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  .other-work {
    margin-top: 64px;
  }

  .other-work__label {
    padding-top: 6px;
  }

  .other-work__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .other-work__row {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 8px 24px;
    align-items: baseline;
    padding-block: 18px;
    border-bottom: 1px solid var(--rule);
  }

  .other-work__row:first-child {
    border-top: 1px solid var(--rule);
  }

  .other-work__year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .other-work__main {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: var(--measure);
  }

  .other-work__project {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: 550;
  }

  .other-work__project a {
    color: var(--ink);
    text-decoration: none;
  }

  .other-work__project a:hover {
    color: var(--accent);
  }

  .other-work__desc {
    font-size: var(--text-sm);
    color: var(--ink);
  }

  .other-work__stack {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .other-work__actions {
    display: flex;
    gap: 18px;
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .other-work__row {
      grid-template-columns: 48px minmax(0, 1fr);
    }

    .other-work__actions {
      grid-column: 2;
    }
  }
</style>
