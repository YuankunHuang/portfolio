---
import { hero, now } from "../data/site";
---

<section class="hero" id="home" aria-label="Introduction">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="hero__name">{hero.name}</p>
      <h1 class="hero__headline">{hero.headline}</h1>
      <p class="hero__subline">{hero.subline}</p>
      <p class="hero__intro prose">{hero.intro}</p>
      <ul class="hero__stats" aria-label="Key facts">
        {hero.stats.map((stat) => <li class="hero__stat">{stat}</li>)}
      </ul>
      <a href={hero.cta.href} class="hero__cta">{hero.cta.label}</a>
    </div>

    <aside class="hero__status" id="now" aria-label="Current status">
      <div class="hero__status-head">
        <p class="section-label">Status</p>
        <p class="hero__status-updated">{now.updated}</p>
      </div>
      <dl class="hero__status-items">
        {
          now.items.map((item, i) => (
            <div class="hero__status-row reveal" style={`--reveal-delay: ${i * 60}ms`}>
              <dt
                class:list={[
                  "hero__status-label",
                  { "hero__status-label--featured": i === 0 },
                ]}
              >
                {item.label}
              </dt>
              <dd class="hero__status-value">{item.value}</dd>
            </div>
          ))
        }
      </dl>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(36px, 6vw, 64px) calc(var(--section-gap) / 2);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: clamp(28px, 4.5vw, 56px);
    align-items: start;
  }

  .hero__name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 14px;
  }

  .hero__headline {
    font-size: var(--text-3xl);
    letter-spacing: -0.015em;
    max-width: 18em;
  }

  .hero__subline {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    margin-top: 16px;
  }

  .hero__intro {
    font-size: var(--text-sm);
    color: var(--ink);
    margin-top: 14px;
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 26px;
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
  }

  .hero__stat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    color: var(--ink);
    position: relative;
  }

  .hero__stat + .hero__stat::before {
    content: "·";
    position: absolute;
    left: -17px;
    color: var(--rule);
  }

  .hero__cta {
    display: inline-block;
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  /* Status ledger */
  .hero__status {
    border: 1px solid var(--hairline);
    border-radius: 6px;
    padding: 18px 20px;
    background: color-mix(in srgb, var(--surface) 55%, transparent);
  }

  .hero__status-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--hairline);
  }

  .hero__status-updated {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    font-variant-numeric: tabular-nums;
    color: var(--muted);
  }

  .hero__status-items {
    margin: 0;
    display: grid;
  }

  .hero__status-row {
    display: grid;
    grid-template-columns: 104px minmax(0, 1fr);
    gap: 4px 16px;
    padding-block: 10px;
  }

  .hero__status-row + .hero__status-row {
    border-top: 1px solid var(--hairline);
  }

  .hero__status-label {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    padding-top: 2px;
  }

  .hero__status-label--featured {
    color: var(--accent-2);
  }

  .hero__status-value {
    margin: 0;
    font-size: var(--text-xs);
    line-height: 1.5;
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 480px) {
    .hero__status-row {
      grid-template-columns: minmax(0, 1fr);
      gap: 2px;
    }
  }
</style>
