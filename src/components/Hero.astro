---
import { Image } from "astro:assets";
import { hero } from "../data/site";
import profile from "../assets/profile.png";
---

<section class="hero" id="home" aria-label="Introduction">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="hero__name">{hero.name}</p>
      <h1 class="hero__headline">{hero.headline}</h1>
      <p class="hero__subline">{hero.subline}</p>
      <p class="hero__intro prose">{hero.intro}</p>
      <ul class="hero__stats" aria-label="Key statistics">
        {hero.stats.map((stat) => <li class="hero__stat">{stat}</li>)}
      </ul>
      <a href={hero.cta.href} class="hero__cta">{hero.cta.label}</a>
    </div>

    <div class="hero__photo">
      <Image
        src={profile}
        alt="Yuankun Huang at his desk, mid-debug session"
        widths={[320, 480, 640, 880]}
        sizes="(max-width: 820px) 60vw, 30vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(48px, 9vw, 112px) calc(var(--section-gap) / 2);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
  }

  .hero__name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .hero__headline {
    font-size: var(--text-3xl);
    letter-spacing: -0.015em;
    max-width: 16em;
  }

  .hero__subline {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    margin-top: 24px;
  }

  .hero__intro {
    font-size: var(--text-md);
    color: var(--ink);
    margin-top: 20px;
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 28px;
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
  }

  .hero__stat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink);
    position: relative;
  }

  .hero__stat + .hero__stat::before {
    content: "·";
    position: absolute;
    left: -18px;
    color: var(--rule);
  }

  .hero__cta {
    display: inline-block;
    margin-top: 40px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  .hero__photo :global(img) {
    border-radius: 6px;
    box-shadow: var(--shadow);
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr);
    }

    /* Reading first on small screens: the photo follows the intro */
    .hero__photo {
      max-width: 240px;
    }
  }
</style>
