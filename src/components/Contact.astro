---
import { contact, site } from "../data/site";
---

<section class="section contact-section" id="contact" aria-label="Contact">
  <div class="container">
    <div class="asymmetric-layout">
      <p class="section-label">Contact</p>

      <div class="contact-section__content">
        <p class="contact-section__message prose reveal">{contact.message}</p>

        <dl class="contact-section__methods">
          {
            contact.methods.map((method, i) => (
              <div class="contact-section__row reveal" style={`--reveal-delay: ${80 + i * 60}ms`}>
                <dt class="contact-section__label">{method.label}</dt>
                <dd class="contact-section__value">
                  <a
                    href={method.href}
                    target={method.href.startsWith("mailto") ? undefined : "_blank"}
                    rel={method.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
                  >
                    {method.value}
                  </a>
                </dd>
              </div>
            ))
          }
          <div class="contact-section__row reveal" style="--reveal-delay: 260ms">
            <dt class="contact-section__label">Resume</dt>
            <dd class="contact-section__value">
              <a href={site.resumeHref} download={site.resumeDownloadName}>
                Resume (PDF) ↓
              </a>
            </dd>
          </div>
        </dl>

        <p class="contact-section__eligibility reveal" style="--reveal-delay: 320ms">
          {contact.eligibility}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    border-top: 1px solid var(--rule);
  }

  .contact-section__message {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.4;
  }

  .contact-section__methods {
    margin: 40px 0 0;
  }

  .contact-section__row {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 24px;
    padding-block: 14px;
    border-bottom: 1px solid var(--rule);
    max-width: 560px;
  }

  .contact-section__row:first-of-type {
    border-top: 1px solid var(--rule);
  }

  .contact-section__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .contact-section__value {
    margin: 0;
    font-size: var(--text-sm);
  }

  .contact-section__value a {
    text-decoration: none;
  }

  .contact-section__eligibility {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    margin-top: 28px;
  }
</style>
